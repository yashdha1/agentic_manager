AZURE_API_KEY=your-azure-api-key-here
AZURE_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_API_VERSION=2024-08-01-preview

# Model names for different usage tiers
AZURE_CHAT_FLAG_MODEL=gpt-4-turbo              # Expensive, used for routing/analysis
AZURE_CHAT_LIGHT_MODEL=gpt-4                  # Standard, used for agent execution
AZURE_EMBEDDING_MODEL=text-embedding-3-small  # For vector embeddings
AZURE_EMBEDDING_DIMENSIONS=1536

GOOGLE_API_KEY=your-google-api-key-here

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=agentics
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/agentics

DB_POOL_SIZE=10                    # Connection pool size
DB_POOL_TIMEOUT=30                 # Query timeout in seconds
 
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                    # Optional, leave empty if no password

# Use in-memory STM instead of Redis (useful if Redis unavailable)
USE_IN_MEMORY_STM=false 

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                    # Optional API key for Qdrant
VECTOR_DIMENSIONS=1536
 
LOG_LEVEL=INFO                    

LANGSMITH_API_KEY=                 # Optional
LANGSMITH_PROJECT=agentics        # Project name in LangSmith
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=

ENVIRONMENT=development           # development, staging, production
PORT=8000
API_HOST=0.0.0.0

# Conversation session timeout (hours)
CONVERSATION_TIMEOUT_HOURS=24

# HITL (Human-In-The-Loop) interrupt timeout (minutes)
HITL_TIMEOUT_MINUTES=30

# LTM (Long-Term Memory) retention (days)
LTM_RETENTION_DAYS=30
 
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=9000
 
NEXT_PUBLIC_API_URL=http://localhost:8000
 
# Cache tool results for this duration (seconds)
TOOL_RESULT_CACHE_TTL=300          # 5 minutes

# Maximum tokens per conversation
MAX_CONVERSATION_TOKENS=10000

# Enable token budgeting (use lighter models when possible)
ENABLE_TOKEN_BUDGETING=true

# ─────────────────────────────────────────────────────────────────
# Security (Production Only)
# ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-here  # Only if multi-user auth enabled
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24